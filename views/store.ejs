<%- include("partials/header") %>
<section class="page-hero compact store-hero">
  <p class="eyebrow">Tienda Infinity</p>
  <h1>Productos fitness</h1>
</section>
<section class="section">
  <form class="filters" action="/tienda" method="get">
    <select name="category">
      <option value="">Todas las categorias</option>
      <% categories.forEach((item) => { %>
        <option value="<%= item.category %>" <%= filters.category === item.category ? "selected" : "" %>><%= item.category %></option>
      <% }) %>
    </select>
    <button class="button primary" type="submit">Filtrar</button>
    <a class="button ghost" href="/mi-cuenta">Mi cuenta</a>
  </form>
  <div class="product-grid">
    <% products.forEach((product) => { %>
      <article class="product-card">
        <img src="<%= product.image_url %>" alt="<%= product.name %>" loading="lazy">
        <div>
          <span class="pill"><%= product.category %></span>
          <h2><%= product.name %></h2>
          <p><%= product.description %></p>
          <div class="product-meta">
            <strong>$<%= Number(String(product.price).replace(/\D/g, "") || 0).toLocaleString("es-CO") %></strong>
            <span><%= product.stock %> disponibles</span>
          </div>
          <a class="button primary full" href="/tienda/<%= product.id %>">Ver producto</a>
        </div>
      </article>
    <% }) %>
  </div>
</section>
<%- include("partials/footer") %>
