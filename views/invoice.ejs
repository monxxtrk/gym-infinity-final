<!DOCTYPE html>
<html lang="es">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Factura <%= invoice.invoiceNumber %> | Gyminfinity</title>
    <meta
      name="description"
      content="Factura y constancia de pago de Gyminfinity."
    />
    <link rel="stylesheet" href="/css/style.css" />
  </head>
  <body>
    <header class="site-header">
      <a href="/" class="brand">
        <img src="/images/logo.svg" alt="Logo de Gyminfinity" class="logo" />
        <div>
          <span class="brand-kicker">Factura Gyminfinity</span>
          <p>Constancia de compra y pago emitida por el sistema.</p>
        </div>
      </a>

      <nav class="nav-bar nav-bar-static" aria-label="Navegacion de factura">
        <% if (viewer.isAdmin) { %>
          <a href="/admin#billing">Facturacion</a>
        <% } else { %>
          <a href="/client">Mi area</a>
        <% } %>
        <button type="button" class="btn btn-primary nav-link" data-print-invoice>Imprimir</button>
      </nav>
    </header>

    <main class="invoice-shell">
      <% if (flash) { %>
        <section class="status-messages">
          <div class="alert alert-<%= flash.type %>"><%= flash.text %></div>
        </section>
      <% } %>

      <section class="invoice-document">
        <div class="invoice-topline">
          <div>
            <span class="section-kicker">Factura de venta</span>
            <h1><%= invoice.invoiceNumber %></h1>
            <p>Fecha de emision: <%= invoice.createdAtLabel %></p>
          </div>

          <div class="invoice-status-box">
            <span class="badge <%= invoice.paymentStatusTone %>"><%= invoice.payment_status || 'Pendiente' %></span>
            <strong><%= invoice.amountLabel %></strong>
            <p><%= invoice.paymentMethodLabel %></p>
          </div>
        </div>

        <div class="invoice-grid">
          <article class="invoice-panel">
            <span class="invoice-label">Emisor</span>
            <h2><%= business.legalName %></h2>
            <p><strong>Marca:</strong> <%= business.name %></p>
            <p><strong>NIT:</strong> <%= business.taxId %></p>
            <p><strong>Direccion:</strong> <%= business.address %></p>
            <p><strong>Ciudad:</strong> <%= business.city %></p>
            <p><strong>Telefono:</strong> <%= business.phone %></p>
            <p><strong>Correo:</strong> <%= business.email %></p>
          </article>

          <article class="invoice-panel">
            <span class="invoice-label">Cliente facturado</span>
            <h2><%= invoice.billing_name || invoice.full_name %></h2>
            <p><strong>Documento/NIT:</strong> <%= invoice.billing_document || 'No registrado' %></p>
            <p><strong>Correo:</strong> <%= invoice.billing_email || invoice.email %></p>
            <p><strong>Telefono:</strong> <%= invoice.billing_phone || 'No registrado' %></p>
            <p><strong>Direccion:</strong> <%= invoice.billing_address || invoice.address %></p>
            <p><strong>Cliente de la cuenta:</strong> <%= invoice.full_name %></p>
          </article>
        </div>

        <div class="invoice-table-wrap">
          <table class="invoice-table">
            <thead>
              <tr>
                <th>Concepto</th>
                <th>Detalle</th>
                <th>Cantidad</th>
                <th>Valor</th>
              </tr>
            </thead>
            <tbody>
              <tr>
                <td><strong><%= invoice.productName %></strong></td>
                <td><%= product?.description || 'Producto o servicio Gyminfinity' %></td>
                <td>1</td>
                <td><%= invoice.amountLabel %></td>
              </tr>
            </tbody>
            <tfoot>
              <tr>
                <td colspan="3">Total</td>
                <td><%= invoice.amountLabel %></td>
              </tr>
            </tfoot>
          </table>
        </div>

        <div class="invoice-grid">
          <article class="invoice-panel invoice-payment-panel">
            <span class="invoice-label">Pago</span>
            <p><strong>Metodo:</strong> <%= invoice.paymentMethodLabel %></p>
            <p><strong>Estado:</strong> <%= invoice.payment_status || 'Pendiente' %></p>
            <p><strong>Referencia:</strong> <%= invoice.payment_reference || 'Sin referencia' %></p>
            <p><strong>Destino del dinero:</strong> <%= invoice.paymentDestination %></p>

            <% if (invoice.payment_method === 'card') { %>
              <p><strong>Tarjeta:</strong> <%= invoice.card_brand || 'Tarjeta' %> terminada en <%= invoice.card_last4 || '----' %></p>
              <p><strong>Titular:</strong> <%= invoice.card_holder || 'No registrado' %></p>
              <p><strong>Cuotas:</strong> <%= invoice.card_installments || 1 %></p>
            <% } else if (invoice.payment_method === 'cash') { %>
              <p><strong>Entrega efectivo:</strong> <%= invoice.cash_receiver || invoice.billing_name || invoice.full_name %></p>
              <p><strong>Notas de caja:</strong> <%= invoice.cash_notes || 'Sin notas registradas' %></p>
            <% } %>
          </article>

          <article class="invoice-panel">
            <span class="invoice-label">Entrega</span>
            <p><strong>Direccion de entrega:</strong> <%= invoice.address %></p>
            <p><strong>Estado del pedido:</strong> <%= invoice.status %></p>
            <p><strong>Factura:</strong> <%= invoice.invoice_status || 'Emitida' %></p>
            <p>Este documento deja constancia interna de la compra y del estado de pago registrado en Gyminfinity.</p>
          </article>
        </div>
      </section>
    </main>

    <footer class="site-footer">
      <p>&copy; <%= currentYear %> Gyminfinity. Factura registrada en el sistema administrativo.</p>
    </footer>
    <script src="/js/main.js"></script>
  </body>
</html>
