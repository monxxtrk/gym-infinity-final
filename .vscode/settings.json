{
  "files.encoding": "utf8",
  "files.eol": "\n",
  "editor.formatOnSave": false,
  "editor.wordWrap": "on",
  "editor.rulers": [
    120
  ],
  "files.exclude": {
    "**/node_modules": true,
    "**/backups": true,
    "**/*.db": true,
    "**/*.db-shm": true,
    "**/*.db-wal": true,
    "**/*.sqlite": true,
    "**/*.sqlite-shm": true,
    "**/*.sqlite-wal": true
  },
  "explorer.fileNesting.enabled": true,
  "explorer.fileNesting.patterns": {
    "package.json": "package-lock.json",
    ".env.example": ".env",
    "gyminfinity.db": "gyminfinity.db-shm, gyminfinity.db-wal",
    "sessions.sqlite": "sessions.sqlite-shm, sessions.sqlite-wal"
  },
  "search.exclude": {
    "**/node_modules": true,
    "**/backups": true,
    "**/*.db": true,
    "**/*.sqlite": true
  }
}
